# Application Environment
APP_ENV=development
PORT=3000
API_PUBLIC_URL=http://localhost:3000
# Comma-separated origins for browsers calling this API (dashboard app URLs).
# Local dashboard origins on :3001 and :3002 are allowed by default; add deployed dashboard URLs here.
# CORS_ALLOWED_ORIGINS=https://your-dashboard.vercel.app

# Remote smoke tests (tests/remote-smoke.mjs, tests/load-smoke.mjs): base URL to probe
# API_BASE_URL=https://your-deployment.vercel.app
# SMOKE_ALLOW_DEGRADED=1

# Database
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net
MONGODB_DB_NAME=delta

# Redis Cache/Queue
UPSTASH_REDIS_REST_URL=https://your-redis-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_redis_token_here

# ImageKit Media Storage
IMAGEKIT_PUBLIC_KEY=your_imagekit_public_key
IMAGEKIT_PRIVATE_KEY=your_imagekit_private_key
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_imagekit_id

# LiveKit Video/Audio
LIVEKIT_URL=wss://your-livekit-instance.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# Better Auth Configuration
BETTER_AUTH_SECRET=your_better_auth_secret_key_min_32_chars
BETTER_AUTH_URL=http://localhost:3000

# JWT Configuration
JWT_ACCESS_SECRET=your_jwt_access_secret_min_32_chars_change_in_production
JWT_REFRESH_SECRET=your_jwt_refresh_secret_min_32_chars_change_in_production

# Email Configuration (Zoho SMTP)
SMTP_HOST=smtp.zoho.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your_email@yourdomain.com
SMTP_PASSWORD=your_zoho_app_password
SMTP_FROM_NAME=Delta
SMTP_FROM_EMAIL=noreply@yourdomain.com

# In-App Purchase Verification
APPLE_IAP_SHARED_SECRET=your_apple_iap_shared_secret
GOOGLE_PLAY_PACKAGE_NAME=com.delta.app

# Push Notifications
PUSH_FCM_SERVER_KEY=your_fcm_server_key

# Logging
LOG_LEVEL=info
