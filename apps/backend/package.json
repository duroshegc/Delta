{
  "name": "backend",
  "version": "1.0.0",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "start": "bun src/index.ts",
    "build": "bun build src/index.ts --outdir ./dist --target bun",
    "typecheck": "tsc --noEmit",
    "db:init": "bun src/scripts/init-db.ts",
    "db:seed": "bun src/scripts/seed-db.ts"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.2",
    "@elysiajs/swagger": "^1.3.1",
    "@upstash/redis": "^1.37.0",
    "better-auth": "^1.6.9",
    "elysia": "^1.4.28",
    "imagekit": "^6.0.0",
    "livekit-server-sdk": "^2.15.2",
    "mongodb": "^7.2.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "zod": "^4.4.2"
  }
}
