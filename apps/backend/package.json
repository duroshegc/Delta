{
  "name": "backend",
  "version": "1.0.0",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "start": "bun src/index.ts",
    "build": "bun build src/index.ts --outdir ./dist --target bun",
    "typecheck": "tsc --noEmit",
    "test": "node --loader ./tests/ts-loader.mjs --experimental-strip-types --experimental-transform-types --test \"tests/**/*.test.ts\"",
    "test:remote": "bun tests/remote-smoke.mjs",
    "test:local:http": "bun tests/local-http-smoke.mjs",
    "test:remote:degraded": "SMOKE_ALLOW_DEGRADED=1 bun tests/remote-smoke.mjs",
    "test:load": "node tests/load-smoke.mjs",
    "test:media": "node --loader ./tests/ts-loader.mjs --experimental-strip-types --experimental-transform-types tests/media-smoke.mjs",
    "db:init": "bun src/scripts/init-db.ts",
    "db:seed": "bun src/scripts/seed-db.ts",
    "admin:create-master": "bun src/scripts/create-master-admin.ts"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/bun": "latest",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/nodemailer": "^8.0.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.2",
    "@elysiajs/swagger": "^1.3.1",
    "@upstash/redis": "^1.37.0",
    "bcrypt": "^6.0.0",
    "better-auth": "^1.6.9",
    "elysia": "^1.4.28",
    "imagekit": "^6.0.0",
    "jsonwebtoken": "^9.0.3",
    "livekit-server-sdk": "^2.15.2",
    "mongodb": "^7.2.0",
    "nodemailer": "^8.0.7",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "zod": "^4.4.2"
  }
}
